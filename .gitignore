model.xgb               # XGBoost model — removed from active scoring pipeline
*.xgb
*.pkl
*.joblib

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# ── OS / editor noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/
