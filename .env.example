# ThrottleGuard — Environment Variables
# Copy this file to .env for local dev. Set these in Railway for production.
# NEVER commit .env to source control.

# ── Required ──────────────────────────────────────────────────────────────────

# Supabase PostgreSQL connection string.
# Stores user accounts (tg_users) and prediction history (tg_predictions).
# Tables are created automatically on first launch.
# On Railway: Settings → Variables → add DATABASE_URL
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Default admin account password — created on first launch if no users exist.
# Change this immediately after first login via the User Management panel.
# On Railway: Settings → Variables → add TG_ADMIN_PASSWORD
TG_ADMIN_PASSWORD=ChangeMe_OnFirstLogin!

# ── Optional ──────────────────────────────────────────────────────────────────

# Not currently used by ThrottleGuard (used by Fleet Optimizer).
# Leave blank or omit unless integrating with Fleet Optimizer session auth.
# SESSION_SECRET=your-random-secret-here
